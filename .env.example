# Copy to .env and adjust (never commit .env)
# Industry standard: config in env vars, secrets in .env / cloud secret manager

# --- Vector database (docker compose sets QDRANT_HOST=qdrant inside containers) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# --- LLM (Ollama on host, or cloud OpenAI) ---
OLLAMA_HOST=http://localhost:11434
# GENERATION_PROVIDER=ollama
# GENERATION_MODEL=llama3.2:3b

# --- Optional paid LLM ---
# GENERATION_PROVIDER=openai
# GENERATION_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here

# --- Frontend (docs/index.html reads API URL from browser localStorage; default below) ---
# Default API for local dev: http://127.0.0.1:8000
# Production: https://your-api.onrender.com
